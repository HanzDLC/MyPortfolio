{
  "permissions": {
    "allow": [
      "Bash(python -c ' *)",
      "Bash(python generate_response_doc.py)",
      "mcp__playwright__browser_evaluate",
      "Bash(curl -s \"https://hanzdlc-portfolio.vercel.app/static/styles.css?cb=$\\(date +%s\\)\")",
      "Bash(curl -s \"https://hanzdlc-portfolio.vercel.app/?cb=$\\(date +%s\\)\")",
      "WebFetch(domain:www.sbs.ox.ac.uk)",
      "mcp__playwright__browser_snapshot",
      "Bash(python .claude/hooks/update_kb.py)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "& '.\\.claude\\hooks\\load-portfolio-context.ps1'",
            "shell": "powershell",
            "timeout": 10,
            "statusMessage": "Loading portfolio KB and recent logs..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "& '.\\.claude\\hooks\\update-kb-on-idle.ps1'",
            "shell": "powershell",
            "timeout": 8,
            "statusMessage": "Scheduling idle KB refresh (5 min)..."
          }
        ]
      }
    ]
  }
}
